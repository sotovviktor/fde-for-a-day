# Azure OpenAI.
AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com/
AZURE_OPENAI_API_VERSION=2024-10-21

# API-key auth (local dev). Leave empty/unset to use managed identity instead.
AZURE_OPENAI_API_KEY=your-api-key-here

# Managed-identity auth only: client ID of the user-assigned identity that holds the
# "Cognitive Services OpenAI User" role on Foundry. Set by Pulumi in Azure; leave
# unset locally (DefaultAzureCredential falls back to your `az login`).
# AZURE_CLIENT_ID=<user-assigned-identity-client-id>

# Per-task Azure deployment
TRIAGE_MODEL=gpt-5.4-nano
# EXTRACT_MODEL must be a vision-capable deployment.
EXTRACT_MODEL=gpt-5.4-nano
ORCHESTRATE_MODEL=gpt-5.4-nano

# Shared LLM client tuning
LLM_TIMEOUT_SECONDS=10
LLM_MAX_RETRIES=3
MAX_DESCRIPTION_CHARS=8000

# Task 1 (signal triage) tuning (optional; defaults shown)
TRIAGE_MAX_OUTPUT_TOKENS=800
# On an Azure content-filter / jailbreak block, retry once with the description
# clamped to this many characters.
TRIAGE_CONTENT_FILTER_RETRY_CHARS=400

# Task 2 (document extraction) tuning. Keep EXTRACT_TIMEOUT_SECONDS x
# (LLM_MAX_RETRIES + 1) under the platform's 60s deadline.
EXTRACT_TIMEOUT_SECONDS=18
EXTRACT_MAX_OUTPUT_TOKENS=4096
MAX_IMAGE_BYTES=8000000

# Task 3 orchestration tuning (optional; defaults shown)
ORCHESTRATE_MAX_ROUNDS=4
ORCHESTRATE_MAX_TOOL_CALLS=30
TOOL_TIMEOUT_SECONDS=5
TOOL_MAX_RETRIES=1
MAX_TOOL_CONCURRENCY=8
ORCHESTRATE_MAX_OUTPUT_TOKENS=1200
